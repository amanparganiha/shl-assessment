# ---- Required ----
# Your OpenAI API key (used for BOTH chat and embeddings by default).
OPENAI_API_KEY=sk-your-key-here

# ---- Optional (defaults shown) ----
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Per-call safety budget (the evaluator times out at 30s; we stay well under).
REQUEST_TIMEOUT_S=20
LLM_MAX_RETRIES=2
RETRIEVAL_TOP_K=40
MAX_RECOMMENDATIONS=10

# ---- Only needed for OpenAI-compatible providers (Groq / OpenRouter / Gemini) ----
# Chat via a compatible endpoint:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# CHAT_MODEL=llama-3.3-70b-versatile
# Embeddings via a compatible endpoint (leave OpenAI if you have a key):
# EMBED_BASE_URL=
# EMBED_API_KEY=
